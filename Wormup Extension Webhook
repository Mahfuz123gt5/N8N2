    {
      "parameters": {
        "jsCode": "// Smart Warmup Logic\n// Format:\n// Queued,Inbox,Category,Spam,Date\n\nfor (const item of $input.all()) {\n\n    const days = [\n        item.json['Day 1'],\n        item.json['Day 2'],\n        item.json['Day 3'],\n        item.json['Day 4'],\n        item.json['Day 5'],\n        item.json['Day 6'],\n        item.json['Day 7']\n    ];\n\n    const validDays = [];\n\n    // সব valid day collect করা\n    for (const day of days) {\n        if (day && !day.includes(\",,,,\") && day.trim() !== \"\") {\n            validDays.push(day);\n        }\n    }\n\n    // Default output\n    let next_day_send_count = 10;\n    let daily_increase_rate = 0;\n    let reason = \"কোনো valid data পাওয়া যায়নি।\";\n\n    if (validDays.length > 0) {\n\n        const latestDay = validDays[validDays.length - 1];\n        const previousDay = validDays.length > 1 ? validDays[validDays.length - 2] : null;\n\n        const parseDay = (day) => {\n            const parts = day.split(',');\n            return {\n                queued: parseInt(parts[0]) || 0,\n                inbox: parseInt(parts[1]) || 0,\n                category: parseInt(parts[2]) || 0,\n                spam: parseInt(parts[3]) || 0,\n                date: parts.slice(4).join(',').trim()\n            };\n        };\n\n        const latest = parseDay(latestDay);\n        const previous = previousDay ? parseDay(previousDay) : null;\n\n        const latestOtherFilters = latest.queued + latest.category + latest.spam;\n        const previousOtherFilters = previous ? (previous.queued + previous.category + previous.spam) : null;\n\n        // Base send count = latest inbox\n        next_day_send_count = latest.inbox;\n\n        // যদি latest day-তে inbox ছাড়া অন্য কিছু থাকে, increase হবে না\n        if (latestOtherFilters > 0) {\n            daily_increase_rate = 0;\n            next_day_send_count = latest.inbox;\n            reason = `${latest.date} তারিখে Inbox ছাড়া অন্য filter দেখা গেছে, তাই increase বন্ধ রাখা হয়েছে।`;\n        }\n        else {\n            // Latest day clean\n            // এখন previous day-ও clean কিনা দেখা হবে\n            if (previous && previousOtherFilters === 0) {\n                // পরপর ২ দিন সব ঠিক থাকলে বেশি increase\n                daily_increase_rate = 10;\n                next_day_send_count = latest.inbox + 10;\n                reason = `${latest.date} এবং আগের দিন—দুই দিনই সবকিছু ঠিক ছিল, তাই বেশি increase করা হয়েছে।`;\n            } else {\n                // শুধু latest day clean হলে normal increase\n                daily_increase_rate = 5;\n                next_day_send_count = latest.inbox + 5;\n                reason = `${latest.date} তারিখে শুধু Inbox ছিল, তাই normal increase করা হয়েছে।`;\n            }\n        }\n    }\n\n    item.json.next_day_send_count = next_day_send_count;\n    item.json.daily_increase_rate = daily_increase_rate;\n    item.json.reason = reason;\n}\n\nreturn $input.all();"
      },
