        "jsCode": "// INPUT START TIME\nconst startInput = $json.Time || \"2026-05-15T13:35:45.157Z\";\n\n// CONVERT START TIME TO UNIX TIMESTAMP\nconst startTimestamp = Math.floor(\n  new Date(startInput).getTime() / 1000\n);\n\n// CURRENT TIME AS END TIME\nconst endTimestamp = Math.floor(Date.now() / 1000);\n\n// RETURN OUTPUT\nreturn {\n  json: {\n    start_time: startInput,\n    start_time_unix: startTimestamp,\n    end_time_unix: endTimestamp\n  }\n};"
